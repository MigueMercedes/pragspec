{
  "name": "pragspec",
  "version": "0.2.0",
  "description": "Pragmatic Spec-Driven Development — npm CLI that scaffolds the SDD pipeline (specs, prompts, skills, ADR/runbook conventions) into any project. Tool-agnostic via AGENTS.md.",
  "type": "module",
  "bin": {
    "pragspec": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "lib/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "sdd",
    "spec-driven-development",
    "scaffolding",
    "ai-coding",
    "agents-md",
    "claude-code",
    "codex",
    "cursor",
    "gemini-cli"
  ],
  "author": "Miguel Mercedes <lmyguel0324@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MigueMercedes/pragspec.git"
  },
  "homepage": "https://github.com/MigueMercedes/pragspec#readme",
  "bugs": {
    "url": "https://github.com/MigueMercedes/pragspec/issues"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "kleur": "^4.1.5",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "vitest": "^2.1.0"
  }
}
